generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // ⚠️ لاحقًا غيرها PostgreSQL
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// 📌 ENUMS
//////////////////////////////////////////////////

enum PlanType {
  FREE
  PRO
  PREMIUM
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum UsageStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

//////////////////////////////////////////////////
// 👤 USER
//////////////////////////////////////////////////

model User {
  id      String  @id @default(cuid())
  clerkId String  @unique
  email   String? @unique

  plan    PlanType @default(FREE)
  credits Int      @default(10)

  lemonCustomerId     String?
  lemonSubscriptionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  subscriptions  Subscription[]
  payments       Payment[]
  videoJobs      VideoJob[]
  usage          Usage[]
  notifications  Notification[]
  manualPayments ManualPayment[]
  images         Image[]
  voices         Voice[]

  // ✅ FIX
  abandonedCheckouts AbandonedCheckout[]
}

//////////////////////////////////////////////////
// 💳 SUBSCRIPTION
//////////////////////////////////////////////////

model Subscription {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  lemonSubscriptionId String? @unique
  lemonCustomerId     String?

  status String
  plan   PlanType

  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////
// 💰 PAYMENT
//////////////////////////////////////////////////

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount   Float
  currency String

  lemonOrderId String? @unique

  status PaymentStatus @default(COMPLETED)

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////
// 📊 USAGE (🔥 FIXED RELATION)
//////////////////////////////////////////////////

model Usage {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type String
  cost Int

  status   UsageStatus @default(PENDING)
  refunded Boolean     @default(false)

  referenceId String?

  createdAt DateTime @default(now())

  // ✅ FIX (important)
  videoJobs VideoJob[]

  @@index([userId])
  @@index([status])
  @@index([referenceId])
}

//////////////////////////////////////////////////
// 🎬 VIDEO JOB (CORE)
//////////////////////////////////////////////////

model VideoJob {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  prompt String

  status JobStatus @default(PENDING)

  priority Int @default(0)

  resultUrl String?
  error     String?

  attempts    Int @default(0)
  maxAttempts Int @default(3)

  usageId String?
  usage   Usage?  @relation(fields: [usageId], references: [id])

  startedAt  DateTime?
  finishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([userId])
  @@index([priority, createdAt])
}

//////////////////////////////////////////////////
// 🖼 IMAGE
//////////////////////////////////////////////////

model Image {
  id String @id @default(cuid())

  url    String
  prompt String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////
// 🎙 VOICE
//////////////////////////////////////////////////

model Voice {
  id String @id @default(cuid())

  url  String
  text String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////
// 🔔 NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  title   String
  message String

  read Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////
// 💳 MANUAL PAYMENT
//////////////////////////////////////////////////

model ManualPayment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  plan     String
  method   String
  amount   Float
  currency String @default("USD")

  screenshotUrl String?

  transactionId String?

  ipAddress String?
  device    String?

  aiScore   Float?
  aiRawText String?

  status    String  @default("PENDING")
  verified  Boolean @default(false)
  riskLevel String?

  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////
// ⚠️ ABANDONED CHECKOUT (FIXED)
//////////////////////////////////////////////////

model AbandonedCheckout {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  email String?
  plan  String

  checkoutUrl String

  orderId String? @unique

  recovered Boolean @default(false)
  step      String  @default("checkout_started")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

//////////////////////////////////////////////////
// 🔐 WEBHOOK IDEMPOTENCY
//////////////////////////////////////////////////

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}
