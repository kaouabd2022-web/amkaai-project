generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // يمكنك تغييره لاحقًا إلى postgresql
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// 👤 USER
//////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String?  @unique

  // 💳 Subscription state
  plan      String   @default("free")
  isPro     Boolean  @default(false)

  // Lemon Squeezy IDs
  lemonCustomerId     String?
  lemonSubscriptionId String?

  // Credits system
  credits   Int      @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions       Subscription[]
  payments            Payment[]
  images              Image[]
  videos              Video[]
  videoJobs           VideoJob[]
  voices              Voice[]
  usage               Usage[]
  abandonedCheckouts  AbandonedCheckout[]
  manualPayments      ManualPayment[]
  notifications       Notification[]
}

//////////////////////////////////////////////////
// 💳 SUBSCRIPTION
//////////////////////////////////////////////////

model Subscription {
  id        String   @id @default(cuid())
  userId    String

  lemonSubscriptionId String? @unique
  lemonCustomerId     String?

  status    String
  plan      String

  currentPeriodEnd DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////
// 💰 PAYMENT
//////////////////////////////////////////////////

model Payment {
  id        String   @id @default(cuid())
  userId    String

  amount    Float
  currency  String

  lemonOrderId String? @unique

  status    String   @default("completed")

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////////////////////////////////
// 📊 USAGE TRACKING
//////////////////////////////////////////////////

model Usage {
  id        String   @id @default(cuid())
  userId    String

  type      String
  cost      Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
}

//////////////////////////////////////////////////
// 🖼 IMAGE
//////////////////////////////////////////////////

model Image {
  id        String   @id @default(cuid())
  url       String
  prompt    String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////////////////////////////////
// 🎬 VIDEO
//////////////////////////////////////////////////

model Video {
  id        String   @id @default(cuid())
  url       String?
  prompt    String
  status    String   @default("pending")
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([status])
}

//////////////////////////////////////////////////
// 🚀 VIDEO JOB QUEUE
//////////////////////////////////////////////////

model VideoJob {
  id        String   @id @default(cuid())
  userId    String

  prompt    String?
  status    String   @default("pending")
  priority  Int      @default(0)
  resultUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
}

//////////////////////////////////////////////////
// 🎙 VOICE
//////////////////////////////////////////////////

model Voice {
  id        String   @id @default(cuid())
  url       String
  text      String
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////////////////////////////////
// ⚠️ ABANDONED CHECKOUT
//////////////////////////////////////////////////

model AbandonedCheckout {
  id            String   @id @default(cuid())
  userId        String?

  email         String?
  plan          String
  checkoutUrl   String

  // Lemon Squeezy order/checkout ref
  orderId       String?  @unique

  recovered     Boolean  @default(false)
  step          String   @default("checkout_started")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////////////////////////////////
// 🔔 NOTIFICATION
//////////////////////////////////////////////////

model Notification {
  id        String   @id @default(cuid())
  userId    String

  title     String
  message   String
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

//////////////////////////////////////////////////
// 💳 MANUAL PAYMENT (Anti-Fraud Ready)
//////////////////////////////////////////////////

model ManualPayment {
  id        String   @id @default(cuid())

  userId    String
  plan      String
  method    String
  amount    Float
  currency  String   @default("USD")

  screenshotUrl String?

  rip           String?
  transactionId String?
  imageHash     String?

  ipAddress     String?
  device        String?

  aiScore       Float?
  aiRawText     String?

  verified      Boolean   @default(false)
  status        String    @default("PENDING")
  riskLevel     String?

  approvedBy    String?
  rejectedBy    String?
  rejectReason  String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////////////////////////////////
// 🔐 WEBHOOK IDEMPOTENCY (VERY IMPORTANT)
//////////////////////////////////////////////////

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
}