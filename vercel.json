{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "functions": {
    "app/api/**": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/worker",
      "schedule": "*/5 * * * *"
    }
  ]
}